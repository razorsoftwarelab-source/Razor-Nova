<Window x:Class="RazorNova.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Razor Nova"
        Width="980" Height="640" MinWidth="760" MinHeight="480"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="36" CornerRadius="8" GlassFrameThickness="0" ResizeBorderThickness="6"/>
    </shell:WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="84"/>
        </Grid.RowDefinitions>

        <!-- ===================== Title Bar ===================== -->
        <Grid Grid.Row="0" Background="{DynamicResource TitleBarBackgroundBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Razor Nova" Margin="14,0,0,0"
                       VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource SecondaryTextBrush}"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                <Button Style="{StaticResource TitleBarButtonStyle}" Click="CycleTheme_Click" ToolTip="Theme">
                    <Viewbox Width="13" Height="13">
                        <Canvas Width="14" Height="14">
                            <Ellipse Width="14" Height="14" Fill="{DynamicResource PrimaryTextBrush}"/>
                            <Ellipse Width="11" Height="11" Canvas.Left="5" Canvas.Top="-1"
                                     Fill="{DynamicResource TitleBarBackgroundBrush}"/>
                        </Canvas>
                    </Viewbox>
                </Button>
                <Button Style="{StaticResource TitleBarButtonStyle}" Click="AboutButton_Click" ToolTip="About">
                    <Viewbox Width="13" Height="13">
                        <Canvas Width="14" Height="14">
                            <Ellipse Width="13" Height="13" Canvas.Left="0.5" Canvas.Top="0.5"
                                     Stroke="{DynamicResource PrimaryTextBrush}" StrokeThickness="1.1"/>
                            <Ellipse Width="1.6" Height="1.6" Canvas.Left="6.2" Canvas.Top="3.2"
                                     Fill="{DynamicResource PrimaryTextBrush}"/>
                            <Line X1="7" Y1="6.5" X2="7" Y2="10.5"
                                  Stroke="{DynamicResource PrimaryTextBrush}" StrokeThickness="1.4"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                        </Canvas>
                    </Viewbox>
                </Button>

                <Button Style="{StaticResource TitleBarButtonStyle}" Command="{x:Static SystemCommands.MinimizeWindowCommand}">
                    <Path Width="10" Height="1" Stretch="Fill" Stroke="{DynamicResource PrimaryTextBrush}" StrokeThickness="1"
                          Data="M0,0 L10,0"/>
                </Button>
                <Button Style="{StaticResource TitleBarButtonStyle}" Click="ToggleMaximizeRestore_Click">
                    <Path Width="10" Height="10" Stroke="{DynamicResource PrimaryTextBrush}" StrokeThickness="1"
                          Data="M0,0 L10,0 L10,10 L0,10 Z"/>
                </Button>
                <Button Style="{StaticResource TitleBarCloseButtonStyle}" Command="{x:Static SystemCommands.CloseWindowCommand}">
                    <Path Width="10" Height="10" Stroke="{DynamicResource PrimaryTextBrush}" StrokeThickness="1"
                          Data="M0,0 L10,10 M10,0 L0,10"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ===================== Main Content ===================== -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="16,8,16,0">
                <RadioButton x:Name="LibraryTabButton" GroupName="MainTabs" IsChecked="True"
                             Style="{StaticResource TabButtonStyle}" Content="Library" Margin="0,0,24,0"/>
                <RadioButton x:Name="PlaylistTabButton" GroupName="MainTabs"
                             Style="{StaticResource TabButtonStyle}" Content="Playlist"/>
            </StackPanel>
            <Border Grid.Row="0" Height="1" VerticalAlignment="Bottom" Background="{DynamicResource DividerBrush}" Margin="0,0,0,0"/>

            <!-- ============ Library Tab ============ -->
            <Grid Grid.Row="1" Visibility="{Binding IsChecked, ElementName=LibraryTabButton, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="16,12,16,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0" Padding="10,7" VerticalContentAlignment="Center"
                             Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource PrimaryTextBrush}"
                             BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1"
                             Text="{Binding Library.SearchText, UpdateSourceTrigger=PropertyChanged}"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="12,0,0,0" VerticalAlignment="Center">
                        <RadioButton Content="Name" GroupName="LibrarySort" Margin="0,0,10,0"
                                     Foreground="{DynamicResource SecondaryTextBrush}"
                                     IsChecked="{Binding Library.SelectedSortCriteria, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Name}"/>
                        <RadioButton Content="Date" GroupName="LibrarySort"
                                     Foreground="{DynamicResource SecondaryTextBrush}"
                                     IsChecked="{Binding Library.SelectedSortCriteria, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=ModifiedDate}"/>
                    </StackPanel>

                    <Button Grid.Column="2" Content="Remove Folder..." Margin="8,0,0,0" Padding="14,7"
                            Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource PrimaryTextBrush}" BorderThickness="0"
                            Command="{Binding Library.RemoveFolderCommand}"
                            IsEnabled="{Binding Library.IsScanning, Converter={StaticResource InverseBooleanConverter}}"/>

                    <Button Grid.Column="3" Content="Add Files..." Margin="8,0,0,0" Padding="14,7"
                            Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource PrimaryTextBrush}" BorderThickness="0"
                            Command="{Binding Library.AddFilesCommand}"
                            IsEnabled="{Binding Library.IsScanning, Converter={StaticResource InverseBooleanConverter}}"/>

                    <Button Grid.Column="4" Content="Scan Folder..." Margin="8,0,0,0" Padding="14,7"
                            Background="{DynamicResource AccentBrush}" Foreground="{DynamicResource AccentForegroundBrush}" BorderThickness="0"
                            Command="{Binding Library.ScanFolderCommand}"
                            IsEnabled="{Binding Library.IsScanning, Converter={StaticResource InverseBooleanConverter}}"/>
                </Grid>

                <ListView Grid.Row="1" Margin="16,0,16,0" Background="Transparent" BorderThickness="0"
                          ItemsSource="{Binding Library.Tracks}"
                          ItemContainerStyle="{StaticResource ThemedListViewItemStyle}"
                          MouseDoubleClick="LibraryTrackListView_MouseDoubleClick">
                    <ListView.View>
                        <GridView ColumnHeaderContainerStyle="{StaticResource ThemedGridViewColumnHeaderStyle}">
                            <GridViewColumn Header="Title" Width="300" DisplayMemberBinding="{Binding Title}"/>
                            <GridViewColumn Header="Artist" Width="200" DisplayMemberBinding="{Binding Artist}"/>
                            <GridViewColumn Header="Album" Width="200" DisplayMemberBinding="{Binding Album}"/>
                            <GridViewColumn Header="Duration" Width="90">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Duration, Converter={StaticResource TimeSpanToShortStringConverter}}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="" Width="40">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="+" Width="22" Height="22" ToolTip="Add to selected playlist"
                                                Background="Transparent" Foreground="{DynamicResource SecondaryTextBrush}" BorderThickness="0"
                                                CommandParameter="{Binding}"
                                                Command="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DataContext.Playlist.AddTrackToSelectedPlaylistCommand}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="" Width="40">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="✕" Width="22" Height="22" ToolTip="Remove from library"
                                                Background="Transparent" Foreground="{DynamicResource SecondaryTextBrush}" BorderThickness="0"
                                                CommandParameter="{Binding}"
                                                Command="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DataContext.Library.DeleteTrackCommand}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>

                <TextBlock Grid.Row="1" Text="Your library is empty. Scan a folder or add files to get started."
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="{DynamicResource SecondaryTextBrush}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Library.Tracks.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <Border Grid.Row="0" Grid.RowSpan="2" Background="#CC0D0D0D"
                        Visibility="{Binding Library.IsScanning, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Library.ImportStatusText}" FontSize="16" HorizontalAlignment="Center" Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <TextBlock Margin="0,8,0,0" HorizontalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0} files found — {1}">
                                    <Binding Path="Library.ScanFilesFoundCount"/>
                                    <Binding Path="Library.ScanTotalDuration" Converter="{StaticResource TimeSpanToShortStringConverter}"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                        <Button Content="Cancel" Margin="0,16,0,0" Padding="16,6" HorizontalAlignment="Center"
                                Background="Transparent" Foreground="{DynamicResource PrimaryTextBrush}"
                                BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1"
                                Command="{Binding Library.CancelScanCommand}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ============ Playlist Tab ============ -->
            <Grid Grid.Row="1" Visibility="{Binding IsChecked, ElementName=PlaylistTabButton, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="16,12,16,8">
                        <Button Content="+ New Playlist" Padding="10,7"
                                Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource PrimaryTextBrush}" BorderThickness="0"
                                Command="{Binding Playlist.NewPlaylistCommand}"/>
                        <Button Content="🗑 Delete" Padding="10,7" Margin="8,0,0,0"
                                Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource PrimaryTextBrush}" BorderThickness="0"
                                Command="{Binding Playlist.DeletePlaylistCommand}"/>
                    </StackPanel>

                    <!-- ★★★ اصلاح نهایی: حذف DisplayMemberPath و استفاده از ItemTemplate ★★★ -->
                    <ListBox Grid.Row="1" Margin="8,0,8,8" Background="Transparent"
                             BorderThickness="0"
                             ItemsSource="{Binding Playlist.Playlists}"
                             SelectedItem="{Binding Playlist.SelectedPlaylist, Mode=TwoWay}"
                             ItemContainerStyle="{StaticResource ThemedListBoxItemStyle}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>

                <Border Grid.Column="0" Width="1" HorizontalAlignment="Right" Background="{DynamicResource DividerBrush}"/>

                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="16,12,16,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="RenameTextBox" Grid.Column="0" Padding="8,6" MaxWidth="240" HorizontalAlignment="Left"
                                 Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource PrimaryTextBrush}"
                                 BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1"
                                 Text="{Binding Playlist.RenameText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Grid.Column="1" Content="Rename" Margin="8,0,0,0" Padding="10,6"
                                Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource PrimaryTextBrush}" BorderThickness="0"
                                Command="{Binding Playlist.RenamePlaylistCommand}"/>
                        <RadioButton Grid.Column="2" Content="Name" GroupName="PlaylistSort" Margin="14,0,8,0" VerticalAlignment="Center"
                                     Foreground="{DynamicResource SecondaryTextBrush}"
                                     IsChecked="{Binding Playlist.SelectedSortCriteria, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Name}"/>
                        <RadioButton Grid.Column="3" Content="Date" GroupName="PlaylistSort" VerticalAlignment="Center" Margin="0,0,14,0"
                                     Foreground="{DynamicResource SecondaryTextBrush}"
                                     IsChecked="{Binding Playlist.SelectedSortCriteria, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=ModifiedDate}"/>
                        <Button Grid.Column="4" Content="▶ Play All" Padding="10,6"
                                Background="{DynamicResource AccentBrush}" Foreground="{DynamicResource AccentForegroundBrush}" BorderThickness="0"
                                Command="{Binding Playlist.PlaySelectedPlaylistCommand}"/>
                    </Grid>

                    <ListView Grid.Row="1" Margin="16,0,16,0" Background="Transparent" BorderThickness="0"
                              ItemsSource="{Binding Playlist.SelectedPlaylistTracks}"
                              ItemContainerStyle="{StaticResource ThemedListViewItemStyle}"
                              MouseDoubleClick="PlaylistTrackListView_MouseDoubleClick">
                        <ListView.View>
                            <GridView ColumnHeaderContainerStyle="{StaticResource ThemedGridViewColumnHeaderStyle}">
                                <GridViewColumn Header="Title" Width="280" DisplayMemberBinding="{Binding Title}"/>
                                <GridViewColumn Header="Artist" Width="180" DisplayMemberBinding="{Binding Artist}"/>
                                <GridViewColumn Header="Duration" Width="90">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Duration, Converter={StaticResource TimeSpanToShortStringConverter}}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="" Width="40">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="✕" Width="22" Height="22" ToolTip="Remove from playlist"
                                                    Background="Transparent" Foreground="{DynamicResource SecondaryTextBrush}" BorderThickness="0"
                                                    CommandParameter="{Binding}"
                                                    Command="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DataContext.Playlist.RemoveTrackFromSelectedPlaylistCommand}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Grid>
        </Grid>

        <!-- ===================== Player Controls Bar ===================== -->
        <Grid Grid.Row="2" Background="{DynamicResource SurfaceBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="200"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="16,0" VerticalAlignment="Center">
                <Border Width="56" Height="56" CornerRadius="4" ClipToBounds="True">
                    <Image Stretch="UniformToFill" Source="{Binding PlayerControls.AlbumArtData, Converter={StaticResource ByteArrayToImageSourceConverter}}"/>
                </Border>
                <StackPanel Margin="12,0,0,0" VerticalAlignment="Center" MaxWidth="160">
                    <TextBlock Text="{Binding PlayerControls.TrackTitle}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"
                               Foreground="{DynamicResource PrimaryTextBrush}"/>
                    <TextBlock Text="{Binding PlayerControls.TrackArtist}" FontSize="12" TextTrimming="CharacterEllipsis"
                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <ToggleButton Style="{StaticResource IconToggleButtonStyle}"
                                  IsChecked="{Binding PlayerControls.IsShuffleEnabled, Mode=OneWay}"
                                  Command="{Binding PlayerControls.ToggleShuffleCommand}">
                        <Viewbox Width="14" Height="14">
                            <Canvas Width="14" Height="14">
                                <Path Data="M1,10 L4,10 Q8,10 8,6 L8,3.2"
                                      Stroke="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=Foreground}"
                                      StrokeThickness="1.3" Fill="Transparent"/>
                                <Polygon Points="6.3,1.5 10,1.5 8,4.3"
                                         Fill="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=Foreground}"/>
                                <Path Data="M1,4 L4,4 Q8,4 8,8 L8,10.8"
                                      Stroke="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=Foreground}"
                                      StrokeThickness="1.3" Fill="Transparent"/>
                                <Polygon Points="6.3,12.5 10,12.5 8,9.7"
                                         Fill="{Binding RelativeSource={RelativeSource AncestorType=ToggleButton}, Path=Foreground}"/>
                            </Canvas>
                        </Viewbox>
                    </ToggleButton>

                    <Button Style="{StaticResource TransportButtonStyle}" Margin="10,0,0,0"
                            Command="{Binding PlayerControls.PreviousCommand}">
                        <Viewbox Width="14" Height="14">
                            <Canvas Width="14" Height="14">
                                <Rectangle Width="1.6" Height="10" Canvas.Left="1" Canvas.Top="2"
                                           Fill="{DynamicResource PrimaryTextBrush}"/>
                                <Polygon Points="12,2 12,12 4,7" Fill="{DynamicResource PrimaryTextBrush}"/>
                            </Canvas>
                        </Viewbox>
                    </Button>

                    <Button Style="{StaticResource PlayButtonStyle}" Margin="10,0,0,0"
                            Command="{Binding PlayerControls.PlayPauseCommand}">
                        <TextBlock FontSize="15" Foreground="{DynamicResource AccentForegroundBrush}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="▶"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding PlayerControls.IsPlaying}" Value="True">
                                            <Setter Property="Text" Value="⏸"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button>

                    <Button Style="{StaticResource TransportButtonStyle}" Margin="10,0,0,0"
                            Command="{Binding PlayerControls.NextCommand}">
                        <Viewbox Width="14" Height="14">
                            <Canvas Width="14" Height="14">
                                <Polygon Points="2,2 2,12 10,7" Fill="{DynamicResource PrimaryTextBrush}"/>
                                <Rectangle Width="1.6" Height="10" Canvas.Left="11.4" Canvas.Top="2"
                                           Fill="{DynamicResource PrimaryTextBrush}"/>
                            </Canvas>
                        </Viewbox>
                    </Button>

                    <!-- Repeat Button (Fixed) -->
                    <Grid Margin="10,0,0,0">
                        <Button Command="{Binding PlayerControls.CycleRepeatCommand}"
                                ToolTip="{Binding PlayerControls.Repeat}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource TransportButtonStyle}">
                                    <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding PlayerControls.Repeat}" Value="All">
                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding PlayerControls.Repeat}" Value="One">
                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Viewbox Width="14" Height="14">
                                <Canvas Width="14" Height="14">
                                    <Path Data="M3,4.5 L3,3 Q3,1.5 4.5,1.5 L9.5,1.5 Q11,1.5 11,3 L11,4.3"
                                          Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                          StrokeThickness="1.3" Fill="Transparent"/>
                                    <Polygon Points="9.3,0.3 12.7,3 9.3,4.8"
                                             Fill="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"/>
                                    <Path Data="M11,9.5 L11,11 Q11,12.5 9.5,12.5 L4.5,12.5 Q3,12.5 3,11 L3,9.7"
                                          Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                          StrokeThickness="1.3" Fill="Transparent"/>
                                    <Polygon Points="4.7,13.7 1.3,11 4.7,9.2"
                                             Fill="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"/>
                                </Canvas>
                            </Viewbox>
                        </Button>

                        <Border Background="{DynamicResource AccentBrush}" CornerRadius="6"
                                Width="12" Height="12" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                Margin="0,0,-2,-2" IsHitTestVisible="False">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding PlayerControls.Repeat}" Value="One">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="1" FontSize="8" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-1,0,0"/>
                        </Border>
                    </Grid>
                </StackPanel>

                <Grid Margin="0,6,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="48"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding PlayerControls.TimeDisplayText}" Cursor="Hand"
                               TextAlignment="Center" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}">
                        <TextBlock.InputBindings>
                            <MouseBinding MouseAction="LeftClick" Command="{Binding PlayerControls.ToggleTimeDisplayCommand}"/>
                        </TextBlock.InputBindings>
                    </TextBlock>
                    <Slider Grid.Column="1" Style="{StaticResource ThemedSliderStyle}" Minimum="0"
                            IsMoveToPointEnabled="True"
                            Maximum="{Binding PlayerControls.Duration.TotalSeconds}"
                            Value="{Binding PlayerControls.CurrentPosition.TotalSeconds, Mode=OneWay}"
                            Thumb.DragCompleted="SeekSlider_DragCompleted"
                            PreviewMouseLeftButtonDown="SeekSlider_PreviewMouseLeftButtonDown"/>
                    <TextBlock Grid.Column="2" Margin="6,0,0,0" FontSize="11"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               Text="{Binding PlayerControls.TotalDurationText}"/>
                </Grid>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="16,0" VerticalAlignment="Center">
                <ToggleButton Style="{StaticResource IconToggleButtonStyle}"
                              IsChecked="{Binding PlayerControls.IsMuted, Mode=OneWay}"
                              Command="{Binding PlayerControls.ToggleMuteCommand}">
                    <Viewbox Width="14" Height="14">
                        <Grid Width="14" Height="14">
                            <Canvas Width="14" Height="14">
                                <Polygon Points="1,5 4,5 4,9 1,9" Fill="{DynamicResource PrimaryTextBrush}"/>
                                <Polygon Points="4,5 7,2 7,12 4,9" Fill="{DynamicResource PrimaryTextBrush}"/>
                            </Canvas>
                            <Canvas Width="14" Height="14">
                                <Canvas.Style>
                                    <Style TargetType="Canvas">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding PlayerControls.IsMuted}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Canvas.Style>
                                <Path Data="M9,4 Q11,7 9,10" Stroke="{DynamicResource PrimaryTextBrush}" StrokeThickness="1.2" Fill="Transparent"/>
                                <Path Data="M10.5,2 Q14,7 10.5,12" Stroke="{DynamicResource PrimaryTextBrush}" StrokeThickness="1.2" Fill="Transparent"/>
                            </Canvas>
                            <Canvas Width="14" Height="14">
                                <Canvas.Style>
                                    <Style TargetType="Canvas">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding PlayerControls.IsMuted}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Canvas.Style>
                                <Line X1="9" Y1="4" X2="13" Y2="10" Stroke="{DynamicResource PrimaryTextBrush}" StrokeThickness="1.3"/>
                                <Line X1="13" Y1="4" X2="9" Y2="10" Stroke="{DynamicResource PrimaryTextBrush}" StrokeThickness="1.3"/>
                            </Canvas>
                        </Grid>
                    </Viewbox>
                </ToggleButton>
                <Slider Width="100" Margin="8,0,0,0" Style="{StaticResource ThemedSliderStyle}"
                        Minimum="0" Maximum="100"
                        Value="{Binding PlayerControls.VolumePercent}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>