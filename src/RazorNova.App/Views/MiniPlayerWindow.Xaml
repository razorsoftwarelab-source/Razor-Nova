<Window x:Class="RazorNova.App.Views.MiniPlayerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Razor Nova — Mini Player"
        Width="300" Height="96"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual">

    <Border CornerRadius="10" Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1"
            MouseLeftButtonDown="Root_MouseLeftButtonDown">
        <Grid Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Width="48" Height="48" CornerRadius="4" ClipToBounds="True">
                <Image Stretch="UniformToFill" Source="{Binding AlbumArtData, Converter={StaticResource ByteArrayToImageSourceConverter}}"/>
            </Border>

            <StackPanel Grid.Column="1" Margin="10,0" VerticalAlignment="Center">
                <TextBlock Text="{Binding TrackTitle}" FontWeight="SemiBold" FontSize="12" TextTrimming="CharacterEllipsis"
                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                <TextBlock Text="{Binding TrackArtist}" FontSize="10" TextTrimming="CharacterEllipsis"
                           Foreground="{DynamicResource SecondaryTextBrush}"/>

                <!-- Seek bar, bound to the same singleton PlayerControlsViewModel as MainWindow -->
                <Slider Margin="0,3,0,0" Height="14" Style="{StaticResource ThemedSliderStyle}"
                        Minimum="0" IsMoveToPointEnabled="True"
                        Maximum="{Binding Duration.TotalSeconds}"
                        Value="{Binding CurrentPosition.TotalSeconds, Mode=OneWay}"
                        Thumb.DragCompleted="SeekSlider_DragCompleted"
                        PreviewMouseLeftButtonDown="SeekSlider_PreviewMouseLeftButtonDown"/>

                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                    <Button Style="{StaticResource TransportButtonStyle}" Width="24" Height="24"
                            Command="{Binding PreviousCommand}">
                        <Viewbox Width="10" Height="10">
                            <Canvas Width="14" Height="14">
                                <Rectangle Width="1.6" Height="10" Canvas.Left="1" Canvas.Top="2" Fill="{DynamicResource PrimaryTextBrush}"/>
                                <Polygon Points="12,2 12,12 4,7" Fill="{DynamicResource PrimaryTextBrush}"/>
                            </Canvas>
                        </Viewbox>
                    </Button>

                    <Button Style="{StaticResource PlayButtonStyle}" Width="28" Height="28" Margin="6,0,0,0"
                            Command="{Binding PlayPauseCommand}">
                        <TextBlock FontSize="11" Foreground="{DynamicResource AccentForegroundBrush}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="▶"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                            <Setter Property="Text" Value="⏸"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button>

                    <Button Style="{StaticResource TransportButtonStyle}" Width="24" Height="24" Margin="6,0,0,0"
                            Command="{Binding NextCommand}">
                        <Viewbox Width="10" Height="10">
                            <Canvas Width="14" Height="14">
                                <Polygon Points="2,2 2,12 10,7" Fill="{DynamicResource PrimaryTextBrush}"/>
                                <Rectangle Width="1.6" Height="10" Canvas.Left="11.4" Canvas.Top="2" Fill="{DynamicResource PrimaryTextBrush}"/>
                            </Canvas>
                        </Viewbox>
                    </Button>
                </StackPanel>
            </StackPanel>

            <Button Grid.Column="2" Width="28" Height="28" VerticalAlignment="Top"
                    Background="Transparent" BorderThickness="0" Foreground="{DynamicResource SecondaryTextBrush}"
                    Content="⤢" ToolTip="Restore Main Window"
                    Click="RestoreButton_Click"/>
        </Grid>
    </Border>
</Window>